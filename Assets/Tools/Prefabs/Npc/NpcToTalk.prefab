  anim: {fileID: 0}
  linesForDialog:
  - "\u041E\u043E\u043E\u043E, \u043F\u0440\u0438\u0432\u0435\u0442 \u043F\u0443\u0442\u043D\u0438\u043A!!!"
  - "\u042F \u0441\u043B\u044B\u0448\u0430\u043B \u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C
    \u043F\u043E\u0434\u0437\u0430\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C."
  - "\u0422\u0443\u0442 \u0435\u0441\u0442\u044C \u0441\u043A\u0443\u043F\u0449\u0438\u043A
    \u0440\u0443\u0434\u044B, \u043E\u043D \u043F\u043E\u043A\u0443\u043F\u0430\u0435\u0442
    \u0440\u0443\u0434\u0443 \u0437\u0430 100 \u0441\u0435\u0440\u0435\u0431, \u0430
    \u043A\u0430\u043A \u0440\u0430\u0437 \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0435\u043A\u0443
    \u0435\u0441\u0442\u044C \u0440\u0443\u0434\u0430, \u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0430\u043C \u043C\u043D\u043E\u0433\u043E \u0441\u043A\u0435\u043B\u0435\u0442\u043E\u0432
    \u0442\u0430\u043A \u0447\u0442\u043E \u0431\u0443\u0434\u044C \u043E\u0441\u0442\u0430\u0440\u043E\u0436\u0435\u043D"
